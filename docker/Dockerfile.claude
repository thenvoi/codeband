# Codeband agent — unified image (Claude Code + Codex)
#
# Provides: Both Claude Code and Codex CLIs, plus git, ripgrep, etc.
# Used for: all agent roles (conductor, coders, reviewers, mergemaster).

# ── Build stage ───────────────────────────────────────────────────────────
FROM python:3.12-slim AS builder

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir uv

WORKDIR /build

# Install codeband + band-sdk
COPY pyproject.toml README.md ./
COPY src ./src
RUN uv venv /app/.venv && uv pip install --python /app/.venv/bin/python ".[dev]"

# ── Runtime stage ─────────────────────────────────────────────────────────
FROM python:3.12-slim

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    bash \
    ca-certificates \
    curl \
    git \
    git-lfs \
    jq \
    less \
    nodejs \
    npm \
    openssh-client \
    ripgrep \
    && rm -rf /var/lib/apt/lists/*

# Install latest gh CLI (Debian's is too old — hits GitHub projectCards deprecation)
RUN ARCH=$(dpkg --print-architecture) \
    && GH_VERSION=$(curl -fsSL https://api.github.com/repos/cli/cli/releases/latest | grep -oP '"tag_name":\s*"v\K[^"]+') \
    && curl -fsSL "https://github.com/cli/cli/releases/download/v${GH_VERSION}/gh_${GH_VERSION}_linux_${ARCH}.deb" -o /tmp/gh.deb \
    && dpkg -i /tmp/gh.deb && rm /tmp/gh.deb

# Install Codex CLI (Node.js binary)
RUN npm install -g @openai/codex

RUN pip install --no-cache-dir uv

WORKDIR /app

# Copy venv and source from builder
COPY --from=builder /app/.venv /app/.venv
COPY --from=builder /build/src /app/src

# Ensure Claude CLI binary is executable
RUN CLAUDE_BIN=/app/.venv/lib/python3.12/site-packages/claude_agent_sdk/_bundled/claude \
    && if [ -f "$CLAUDE_BIN" ]; then chmod +x "$CLAUDE_BIN"; fi

# Copy entrypoint and runner
COPY docker/entrypoint.sh /app/docker/entrypoint.sh

RUN useradd -m -u 1000 -s /bin/bash appuser \
    && mkdir -p /workspace/repo.git /workspace/worktrees /workspace/notes /workspace/state \
    && chown -R appuser:appuser /app /workspace

USER appuser
ENV HOME=/home/appuser

# Trust bind-mounted repo directories (must run as appuser so config lands in ~appuser)
RUN git config --global --add safe.directory /workspace/repo.git \
    && git config --global --add safe.directory '/workspace/worktrees/*'
ENV PATH="/home/appuser/.local/bin:/app/.venv/bin:${PATH}"

WORKDIR /workspace

ENTRYPOINT ["bash", "/app/docker/entrypoint.sh"]
